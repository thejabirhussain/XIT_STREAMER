# ─── XIT STREAMER — ENVIRONMENT CONFIGURATION ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── APP ────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql://xit:xit_pass@postgres:5432/xit_streamer
POSTGRES_USER=xit
POSTGRES_PASSWORD=xit_pass
POSTGRES_DB=xit_streamer

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── ENCRYPTION (AES-256-GCM) ───────────────────────────────
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=replace_with_64_char_random_hex

# ─── YOUTUBE ────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/auth/callback/youtube

# ─── META (Facebook + Instagram) ────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/auth/callback/meta
META_WEBHOOK_VERIFY_TOKEN=replace_with_random_string
META_WEBHOOK_SECRET=replace_with_random_string

# ─── MEDIA ENGINE ───────────────────────────────────────────
SRS_HTTP_API=http://srs:1985
SRS_RTMP_HOST=rtmp://srs
SRS_RTMP_PORT=1935
SRS_HLS_BASE_URL=http://localhost:8080/live
MEDIA_ENGINE_PORT=8001
MEDIA_ENGINE_SECRET=replace_with_random_string

# ─── STUN/TURN (WebRTC) ─────────────────────────────────────
STUN_URLS=stun:stun.l.google.com:19302
# TURN_URL=
# TURN_USERNAME=
# TURN_CREDENTIAL=

# ─── RTMPS (Production) ─────────────────────────────────────
# SRS_RTMPS_PORT=1936
# SSL_CERT_PATH=/etc/ssl/certs/xitstreamer.crt
# SSL_KEY_PATH=/etc/ssl/private/xitstreamer.key

# ─── RECORDING (Phase 2 — Placeholder) ──────────────────────
# RECORDING_STORAGE=s3
# S3_BUCKET=xit-streamer-recordings
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── FRONTEND (Vite) ────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
VITE_STUN_URLS=stun:stun.l.google.com:19302
